#!/bin/sh

if [ ! -f "./gradlew" ]; then
    echo "⚠️  gradlew 없음 — 코드 스타일 검사 건너뜀"
    exit 0
fi

echo "🔍 코드 스타일 검사 중..."

./gradlew spotlessCheck --daemon -q
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "❌ 코드 스타일 검사 실패"
    echo "   아래 명령어로 자동 수정 후 다시 커밋하세요."
    echo ""
    echo "   ./gradlew spotlessApply"
    echo ""
    exit 1
fi

echo "✅ 코드 스타일 검사 통과"
exit 0
