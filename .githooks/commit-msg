#!/bin/sh

COMMIT_MSG=$(cat "$1")
PATTERN="^(feat|fix|docs|style|refactor|test|chore): .+\(#[0-9]+\)$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "❌ 커밋 메시지 형식이 올바르지 않습니다."
    echo ""
    echo "   올바른 형식: type: 기능명(#이슈번호)"
    echo "   예시:        feat: 카카오 로그인 구현(#12)"
    echo ""
    echo "   허용 type: feat | fix | docs | style | refactor | test | chore"
    echo ""
    echo "   입력한 메시지: $COMMIT_MSG"
    echo ""
    exit 1
fi

echo "✅ 커밋 메시지 형식 확인 완료"
exit 0
