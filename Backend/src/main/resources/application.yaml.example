app:
  frontend:
    url: http://localhost:3000
  upload:
    path: uploads
    url-prefix: http://localhost:8080/uploads/
jwt:
  secret: dGVzdC1zZWNyZXQta2V5LWZvci10ZXN0aW5nLW9ubHktMTIzNDU2Nzg=
  access-expiration: 3600000
  refresh-expiration: 604800000
cookie:
  # 로컬 HTTP 개발 시 false, 운영 HTTPS 배포 시 true
  secure: false
  same-site: Lax
server:
  servlet:
    session:
      cookie:
        same-site: lax

spring:
  application:
    name: WhatToEat
  output:
    ansi:
      enabled: always
  datasource:
    url: jdbc:mysql://localhost:3306/whattoeat?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    driver-class-name: com.mysql.cj.jdbc.Driver
    username: whattoeat
    password: whattoeat
    hikari:
      auto-commit: false
  jpa:
    show-sql: true
    hibernate:
      ddl-auto: update
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQLDialect
        format_sql: true
        highlight_sql: true
        use_sql_comments: true
  security:
    oauth2:
      client:
        registration:
          kakao:
            client-id: ${KAKAO_CLIENT_ID}
            client-secret: ${KAKAO_CLIENT_SECRET}
            client-authentication-method: client_secret_post
            scope: profile_nickname, profile_image, account_email
            client-name: Kakao
            authorization-grant-type: authorization_code
            redirect-uri: '{baseUrl}/{action}/oauth2/code/{registrationId}'
        provider:
          kakao:
            authorization-uri: https://kauth.kakao.com/oauth/authorize
            token-uri: https://kauth.kakao.com/oauth/token
            user-info-uri: https://kapi.kakao.com/v2/user/me
            user-name-attribute: id
  springdoc:
    default-produces-media-type: application/json;charset=UTF-8
  logging:
    level:
      com.back: DEBUG
      org.hibernate.orm.jdbc.bind: TRACE
      org.hibernate.orm.jdbc.extract: TRACE
      org.springframework.transaction.interceptor: TRACE
  data:
    redis:
      host: localhost
      port: 6379

